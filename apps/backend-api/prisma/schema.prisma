// ============================================================
// Atlas Ride-Hailing Platform - Canonical Schema v1.0
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Identity Domain ---

model User {
  id            String    @id @default(uuid())
  email         String?   @unique  // Optional — set during onboarding, not OTP flow
  fullName      String
  phoneNumber   String    @unique
  role          UserRole  @default(PASSENGER)
  fcmToken      String?   // For push notifications
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerRides Ride[]    @relation("PassengerRides")
  driverProfile Driver?
  
  pushTokens    PushToken[]
  notifications Notification[]
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

// --- Driver Domain ---

model Driver {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id])
  status          DriverStatus @default(OFFLINE)
  currentLat      Float?
  currentLng      Float?
  lastLocationAt  DateTime?
  
  vehicleInfo     Json?        // Details: make, model, year, plate
  rating          Float        @default(5.0)
  
  verification    DriverVerification?
  
  rides           Ride[]
  ledgerEntries   RideLedger[]
  transactions    DriverTransaction[]
  withdrawals     WithdrawalRequest[]
  account         DriverAccount?
  locationHistory DriverLocationHistory[]
}

model DriverVerification {
  id              String       @id @default(uuid())
  driverId        String       @unique
  driver          Driver       @relation(fields: [driverId], references: [id])
  
  status          DriverVerificationStatus @default(PENDING)
  rejectionReason String?
  
  metadata        Json?        // Risk scores, summary
  flags           Json?        // Array of VerificationFlag
  
  reviewedBy      String?      // Admin ID
  reviewedAt      DateTime?
  
  documents       DriverDocument[]
  events          VerificationEvent[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model DriverDocument {
  id              String       @id @default(uuid())
  verificationId  String
  verification    DriverVerification @relation(fields: [verificationId], references: [id])
  
  type            DocumentType
  status          DocumentStatus @default(PENDING)
  
  // Storage Abstraction
  storageProvider String       @default("LOCAL") // LOCAL, S3, R2
  storageKey      String       // The path or key in the bucket
  url             String?      // Optional cached public URL
  
  mimeType        String?
  fileSize        Int?
  checksum        String?
  
  version         Int          @default(1)
  isCurrent       Boolean      @default(true)
  
  expiresAt       DateTime?
  rejectionReason String?
  
  metadata        Json?        // Serial number, issue date
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([verificationId])
}

model VerificationEvent {
  id              String       @id @default(uuid())
  verificationId  String
  verification    DriverVerification @relation(fields: [verificationId], references: [id])
  
  eventType       VerificationEventType
  statusFrom      DriverVerificationStatus?
  statusTo        DriverVerificationStatus?
  
  reason          String?
  actorId         String?      // System or Admin ID
  actorType       String       @default("SYSTEM") // SYSTEM, ADMIN, DRIVER
  
  metadata        Json?
  timestamp       DateTime     @default(now())

  @@index([verificationId])
}

enum DriverVerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum DocumentType {
  IDENTITY_CARD
  DRIVING_LICENSE
  CARTE_GRISE
  INSURANCE_POLICY
  PROFILE_PHOTO
}

enum VerificationEventType {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DOCUMENT_REPLACED
  DOCUMENT_EXPIRED
  SUSPENDED
  UNSUSPENDED
}

enum VerificationFlag {
  BLURRY_DOCUMENT
  EXPIRED_DOCUMENT
  DUPLICATE_IDENTITY
  PHOTO_MISMATCH
  FRAUD_SUSPECTED
}

enum DriverStatus {
  OFFLINE
  AVAILABLE
  BUSY
  ON_TRIP
}

// --- Ride Domain ---

model Ride {
  id              String      @id @default(uuid())
  version         Int         @default(1)
  passengerId     String
  passenger       User        @relation("PassengerRides", fields: [passengerId], references: [id])
  driverId        String?
  driver          Driver?     @relation(fields: [driverId], references: [id])
  
  status          RideStatus  @default(REQUESTED)
  serviceType     String      @default("ECONOMY")
  
  pickupLat       Float
  pickupLng       Float
  pickupAddress   String
  dropoffLat      Float
  dropoffLng      Float
  dropoffAddress  String
  
  estimatedPrice  Decimal     @db.Decimal(10, 2)
  actualPrice     Decimal?    @db.Decimal(10, 2)
  currency        String      @default("MAD")
  
  otpCode         String?     // For physical handshake
  
  requestedAt     DateTime    @default(now())
  acceptedAt      DateTime?
  arrivedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  
  statusHistory   RideStatusHistory[]
  ledgerRecord    RideLedger?
  negotiations    Negotiation[]

  requestId       String?     // Primary request that created this ride
  @@index([passengerId, status])
}

model Negotiation {
  id              String            @id @default(uuid())
  rideId          String
  ride            Ride              @relation(fields: [rideId], references: [id])
  passengerId     String
  driverId        String
  
  proposedPrice   Decimal           @db.Decimal(10, 2)
  counterPrice    Decimal?          @db.Decimal(10, 2)
  
  status          NegotiationStatus @default(PENDING)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([rideId, driverId])
}

enum NegotiationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum RideStatus {
  REQUESTED
  DISPATCHED
  DRIVER_ACCEPTED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model RideStatusHistory {
  id          String     @id @default(uuid())
  rideId      String
  ride        Ride       @relation(fields: [rideId], references: [id])
  fromStatus  RideStatus
  toStatus    RideStatus
  timestamp   DateTime   @default(now())
  requestId   String?    // The request that triggered this status change
}

// --- Financial Domain (The Ledger) ---

model RideLedger {
  id              String   @id @default(uuid())
  rideId          String   @unique
  ride            Ride     @relation(fields: [rideId], references: [id])
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id])
  
  totalAmount     Decimal  @db.Decimal(10, 2)
  driverEarnings  Decimal  @db.Decimal(10, 2) // Total - Company Fee
  companyFee      Decimal  @db.Decimal(10, 2)
  taxes           Decimal  @db.Decimal(10, 2)
  
  status          LedgerStatus @default(PENDING)
  createdAt       DateTime @default(now())
  settledAt       DateTime?
  
  transactions    DriverTransaction[]
}

enum LedgerStatus {
  PENDING
  PROCESSED
  SETTLED
  DISPUTED
}

model DriverAccount {
  id              String   @id @default(uuid())
  driverId        String   @unique
  driver          Driver   @relation(fields: [driverId], references: [id])
  balance         Decimal  @db.Decimal(10, 2) @default(0.0)
  lockedBalance   Decimal  @db.Decimal(10, 2) @default(0.0) // Amount requested but not yet paid
  totalEarned     Decimal  @db.Decimal(10, 2) @default(0.0) // Cumulative lifetime earnings
  totalWithdrawn  Decimal  @db.Decimal(10, 2) @default(0.0) // Cumulative lifetime payouts
  updatedAt       DateTime @updatedAt
}

model DriverTransaction {
  id              String           @id @default(uuid())
  driverId        String
  driver          Driver           @relation(fields: [driverId], references: [id])
  
  type            TransactionType
  amount          Decimal          @db.Decimal(10, 2)
  status          TransactionStatus @default(COMPLETED)
  
  // Explicit relations for data integrity
  rideLedgerId    String?          
  rideLedger      RideLedger?      @relation(fields: [rideLedgerId], references: [id])
  
  withdrawalId    String?
  withdrawal      WithdrawalRequest? @relation(fields: [withdrawalId], references: [id])
  
  referenceType   String?          // e.g., 'RIDE_EARNING', 'WITHDRAWAL', 'MANUAL_ADJUSTMENT'
  
  description     String?
  metadata        Json?
  
  createdAt       DateTime         @default(now())
  
  @@index([driverId, createdAt])
  @@index([rideLedgerId])
  @@index([withdrawalId])
}

model WithdrawalRequest {
  id              String           @id @default(uuid())
  driverId        String
  driver          Driver           @relation(fields: [driverId], references: [id])
  
  amount          Decimal          @db.Decimal(10, 2)
  status          WithdrawalStatus @default(PENDING)
  
  bankDetails     Json?            // RIB, Bank Name, etc.
  
  requestedAt     DateTime         @default(now())
  processedAt     DateTime?
  paidAt          DateTime?
  
  adminId         String?          // Admin who approved/rejected
  notes           String?
  rejectionReason String?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  transactions    DriverTransaction[]

  @@index([status])
}

enum TransactionType {
  CREDIT  // Money coming in (Earnings)
  DEBIT   // Money going out (Withdrawals)
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// --- Event Infrastructure (Outbox Pattern) ---

model OutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  sequence      Int       @unique @default(autoincrement())
  version       Int       @default(1)
  correlationId String?   // Cross-system trace ID
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  @@index([status, createdAt])
}

model DriverLocationHistory {
  id        String   @id @default(uuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  lat       Float
  lng       Float
  timestamp DateTime @default(now())

  @@index([driverId, timestamp])
}

// --- System Configuration Domain ---

model SystemSetting {
  key       String   @id
  value     Json     // Dynamic config: notification strategy, platform fees, etc.
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?  // Admin or User ID who performed the action
  action      String   // e.g., 'UPDATE_COMMISSION', 'SUSPEND_DRIVER'
  entityType  String   // e.g., 'Driver', 'SystemSetting'
  entityId    String?  // The ID of the affected record
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

// --- Integrity & Security Domain ---

model FraudEvent {
  id            String      @id @default(uuid())
  userId        String?
  entityType    String      // 'DRIVER' or 'PASSENGER'
  eventType     FraudType
  severity      RiskLevel   @default(LOW)
  metadata      Json?       // Details like { velocity: '500km/h', mockApp: 'FakeGPS' }
  ipAddress     String?
  deviceId      String?
  createdAt     DateTime    @default(now())

  @@index([userId, eventType])
}

enum FraudType {
  IMPOSSIBLE_TRAVEL
  GPS_SPOOFING
  PRICE_MANIPULATION
  DEVICE_CLONING
  SUSPICIOUS_REFUND
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// --- Growth & Marketing Domain ---

model RewardCampaign {
  id            String         @id @default(uuid())
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean        @default(true)
  prizes        RewardPrize[]
  promoCodes    PromoCode[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RewardPrize {
  id            String         @id @default(uuid())
  campaignId    String
  campaign      RewardCampaign @relation(fields: [campaignId], references: [id])
  type          PrizeType      // DISCOUNT, CASHBACK, FREE_RIDE, PHYSICAL
  name          String
  description   String?
  imageUrl      String?
  probWeight    Int            @default(1) // Weight for weighted-random selection
  stockLimit    Int            @default(0) // 0 for unlimited
  claimedCount  Int            @default(0)
  value         Decimal?       @db.Decimal(10, 2)
  userRewards   UserReward[]
}

enum PrizeType {
  DISCOUNT
  CASHBACK
  FREE_RIDE
  PHYSICAL
}

model PromoCode {
  id              String         @id @default(uuid())
  code            String         @unique
  campaignId      String?
  campaign        RewardCampaign? @relation(fields: [campaignId], references: [id])
  
  type            PromoType      @default(DISCOUNT)
  discountType    DiscountType   @default(PERCENTAGE)
  discountValue   Decimal        @db.Decimal(10, 2)
  
  maxUsageTotal   Int?
  maxUsagePerUser Int            @default(1)
  usedCount       Int            @default(0)
  
  minRideValue    Decimal?       @db.Decimal(10, 2)
  cityRestrictions Json?         // Array of allowed city IDs
  serviceTypes    Json?          // Array of allowed services: Taxi, Delivery, etc.
  
  expiresAt       DateTime
  isActive        Boolean        @default(true)
  usageRecords    PromoUsage[]
  createdAt       DateTime       @default(now())
}

enum PromoType {
  DISCOUNT
  REWARD_TICKET
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  WALLET_CREDIT
}

model PromoUsage {
  id          String   @id @default(uuid())
  promoId     String
  promoCode   PromoCode @relation(fields: [promoId], references: [id])
  userId      String
  rideId      String?
  createdAt   DateTime @default(now())

  @@index([promoId, userId])
}

model UserReward {
  id          String      @id @default(uuid())
  userId      String
  prizeId     String
  prize       RewardPrize @relation(fields: [prizeId], references: [id])
  status      RewardStatus @default(PENDING)
  claimCode   String      @unique // Secret code for physical prize claiming
  wonAt       DateTime    @default(now())
  claimedAt   DateTime?
}

enum RewardStatus {
  PENDING
  CLAIMED
}

// --- Referral Domain ---

model ReferralProgram {
  id              String   @id @default(uuid())
  name            String
  rewardAmount    Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  referralRewards ReferralReward[]
}

model ReferralReward {
  id          String   @id @default(uuid())
  programId   String
  program     ReferralProgram @relation(fields: [programId], references: [id])
  referrerId  String
  refereeId   String   @unique
  status      String   @default("PENDING") // PENDING, COMPLETED (after first ride)
  rewardedAt  DateTime?
}

// --- Notification Domain ---

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String   // ios, android, web
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  data      Json?    // Custom payload
  type      String   // RIDE_REQUEST, TRIP_START, etc.
  status    String   @default("SENT") // SENT, DELIVERED, FAILED, READ
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}
