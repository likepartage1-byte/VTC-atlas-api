{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/backend-api",
  "sourceRoot": "apps/backend-api/src",
  "projects": {
    "backend-api": {
      "type": "application",
      "root": "apps/backend-api",
      "entryFile": "main",
      "sourceRoot": "apps/backend-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/backend-api/tsconfig.app.json",
        "assets": [],
        "deleteOutDir": true
      }
    }
  }
}
